# 小米 MiMo API Key
MIMO_API_KEY=
# 后端 ASR Provider 顺序
AI_PAINTING_ASR_PROVIDERS=xiaomi,local
# 后端 ASR 语种
AI_PAINTING_ASR_LANGUAGE=zh
# 小米 ASR 模型
AI_PAINTING_XIAOMI_ASR_MODEL=mimo-v2.5-asr
# 启用 Drawing Agent 复杂指令规划
AI_PAINTING_ENABLE_AGENT_PLANNER=true
# 旧规划器开关兼容字段
AI_PAINTING_ENABLE_LLM_PLANNER=true
# 小米 MiMo 复杂指令规划模型
AI_PAINTING_MIMO_LLM_MODEL=mimo-v2.5-pro
# 小米 TTS 模型
AI_PAINTING_MIMO_TTS_MODEL=mimo-v2-tts
# 小米 TTS 音色
AI_PAINTING_MIMO_TTS_VOICE=default_zh
# 小米 TTS 风格
AI_PAINTING_MIMO_TTS_STYLE=自然 清晰
# 前端请求后端 API 地址
VITE_API_BASE_URL=http://127.0.0.1:8084
# 后端 SQLite 数据库路径
AI_PAINTING_DB=backend\data\ai_painting.sqlite3
# SQLite 连接页缓存大小, 单位 KiB
AI_PAINTING_SQLITE_CACHE_SIZE_KIB=8192
# 后端 CORS 允许来源
AI_PAINTING_CORS_ORIGINS=http://localhost:3001,http://127.0.0.1:3001
# 本地 ASR HTTP 服务地址
AI_PAINTING_LOCAL_ASR_URL=http://127.0.0.1:9001/asr
# 本地 ASR 前端展示名称
AI_PAINTING_LOCAL_ASR_LABEL=Qwen3-ASR 本地服务
# Qwen3-ASR 模型 ID 或本地目录
QWEN3_ASR_MODEL=Qwen/Qwen3-ASR-0.6B
# Qwen3-ASR 推理设备
QWEN3_ASR_DEVICE=auto
# Qwen3-ASR 推理精度
QWEN3_ASR_DTYPE=auto
# 文字转图片 Provider
AI_PAINTING_IMAGE_PROVIDER=openai_compatible
# 文字转图片中转站 Base URL
AI_PAINTING_TEXT_IMAGE_BASE_URL=https://corenode.best/v1
# 文字转图片模型名称
AI_PAINTING_TEXT_IMAGE_MODEL=gpt-image-2
# 文字转图片 API Key
AI_PAINTING_TEXT_IMAGE_API_KEY=
# 图生图精修 Provider
AI_PAINTING_IMAGE_EDIT_PROVIDER=openai_compatible
# 图生图精修接口 Base URL
AI_PAINTING_IMAGE_EDIT_BASE_URL=https://corenode.best/v1
# 图生图精修模型名称
AI_PAINTING_IMAGE_EDIT_MODEL=gpt-image-2
# 图生图精修 API Key
AI_PAINTING_IMAGE_EDIT_API_KEY=
# 图生图精修响应格式
AI_PAINTING_IMAGE_EDIT_RESPONSE_FORMAT=b64_json
# OpenAI 官方备用 API Key
AI_PAINTING_OPENAI_API_KEY=
# OpenAI 官方备用 Base URL
AI_PAINTING_OPENAI_BASE_URL=https://api.openai.com/v1
# OpenAI 官方标准 API Key
OPENAI_API_KEY=
# OpenAI 官方标准 Base URL
OPENAI_BASE_URL=https://api.openai.com/v1
# OpenAI 官方图片模型
AI_PAINTING_OPENAI_IMAGE_MODEL=gpt-image-2
# OpenAI 官方图片尺寸
AI_PAINTING_OPENAI_IMAGE_SIZE=auto
# OpenAI 官方图片质量
AI_PAINTING_OPENAI_IMAGE_QUALITY=auto
# OpenAI 官方图片输出格式
AI_PAINTING_OPENAI_IMAGE_OUTPUT_FORMAT=png
# PlantUML 本地 jar 路径
AI_PAINTING_PLANTUML_JAR=
# PlantUML Server 地址, 为空时不会上传源码到外部服务
AI_PAINTING_PLANTUML_SERVER_URL=
# PlantUML 渲染安全模式
AI_PAINTING_PLANTUML_SECURITY_PROFILE=SANDBOX
# PlantUML 渲染超时时间, 单位秒
AI_PAINTING_PLANTUML_TIMEOUT_SECONDS=8
# PlantUML 最大源码长度
AI_PAINTING_PLANTUML_MAX_SOURCE_CHARS=12000
# Java 命令路径
AI_PAINTING_JAVA_BIN=java
